{
  "_comment": "LLM Wiki 프로젝트 설정. 이 파일을 프로젝트 루트에 wiki.config.json으로 복사 후 수정.",
  "version": "1.1",

  "project_id": "<agent-name>",
  "mode": "session-extract",
  "_mode_options": ["karpathy-pure", "session-extract", "hybrid"],

  "paths": {
    "wiki_root": "docs/wiki",
    "raw_root": "raw",
    "session_archive_root": "docs/session_archive",
    "sessions_jsonl": "~/.claude/projects/<agent-uuid>/*.jsonl",
    "_note": "sessions_jsonl: ~/.claude/projects/ 하위에서 project UUID 디렉토리 찾기. 또는 claude project list로 확인."
  },

  "sections": [
    {
      "name": "decisions",
      "template": "decision",
      "phase_tag": null,
      "_note": "ADR 스타일 기술 결정. YAML frontmatter + status 필드 권장."
    },
    {
      "name": "concepts",
      "template": "concept",
      "phase_tag": null,
      "_note": "개념 정의 엔티티. 재사용 단위."
    },
    {
      "name": "principles",
      "template": "principle",
      "phase_tag": null,
      "_note": "일반화 원리. 여러 postmortem/실험 교훈에서 추출."
    }
  ],

  "_sections_extended_example": [
    {"name": "ideas",       "template": "idea",       "phase_tag": "P1"},
    {"name": "postmortems", "template": "postmortem", "phase_tag": "P5"},
    {"name": "architecture","template": "entity",     "phase_tag": null},
    {"name": "pipeline",    "template": "entity",     "phase_tag": null},
    {"name": "reference",   "template": "entity",     "phase_tag": null}
  ],

  "auditors": [],
  "_auditors_example": [
    {
      "name": "reality-auditor",
      "model": "opus",
      "trigger": "postmortem-ingest",
      "description": "결과 해석 확증편향 탐지 + 대안 설명 요구"
    }
  ],

  "frontmatter": {
    "_schema_contract": "Dataview + Calendar 호환 통일 스키마. date 는 반드시 인용 없이 ISO YYYY-MM-DD.",
    "required_fields": ["date", "status"],
    "optional_fields": ["aliases", "phase", "scope", "project", "tags", "cssclass"],
    "status_values": ["Draft", "Active", "Accepted", "Implemented", "Superseded", "Archived"],
    "date_format": "YYYY-MM-DD",
    "date_quoted": false,
    "tags_key": "tags",
    "tags_style": "flow"
  },

  "lint_cadence": {
    "every_sessions": 5,
    "every_pages": 10,
    "_note": "세션 카운트는 session-lifecycle 종료 훅에서 별도 관리 필요."
  },

  "obsidian": {
    "vault_path": ".",
    "dataview_enabled": true,
    "graph_exclude_patterns": ["docs/session_archive"],
    "_note": "vault_path는 project_root 기준 상대경로.",
    "daily_notes": {
      "enabled": true,
      "folder": "docs/daily",
      "format": "YYYY-MM-DD",
      "template_path": "docs/templates/daily-note.md",
      "_calendar_plugin_note": "Calendar plugin (liamcain) 은 Daily Notes 플러그인의 format 을 그대로 사용. 반드시 frontmatter date 포맷과 동일한 YYYY-MM-DD 로 유지.",
      "_integration_pattern": "각 wiki 페이지의 frontmatter date 와 daily-note 파일명이 일치하면, Daily Note 내 Dataview 쿼리 (`WHERE date = this.file.day`) 가 자동 수집."
    },
    "cssclasses": {
      "_note": "각 템플릿이 부여하는 cssclass 값. Obsidian CSS snippets 에서 .twk-* 셀렉터로 스타일 지정 가능.",
      "decision": "twk-decision",
      "concept": "twk-concept",
      "principle": "twk-principle",
      "postmortem": "twk-postmortem",
      "idea": "twk-idea",
      "entity": "twk-entity",
      "daily": "twk-daily"
    }
  },

  "naming_conventions": {
    "session_based": "YYYYMMDD_<name>.md",
    "entity": "<name>.md",
    "decision_adr": "YYYY-MM-DD_<kebab-topic>.md",
    "versioned": "YYYYMMDD_<name>_v<n>.md",
    "daily_note": "YYYY-MM-DD.md",
    "_daily_note_note": "Calendar plugin 은 이 포맷의 파일명만 dot 으로 인식. frontmatter date 와 반드시 일치."
  }
}
